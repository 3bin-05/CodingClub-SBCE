rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ──────────────────────────────────────────────────────────────
    // HELPER FUNCTIONS
    // ──────────────────────────────────────────────────────────────

    // Checks if the requesting user is an active admin (any role)
    function isActiveAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.status == 'active';
    }

    // Checks if the requesting user is an active super_admin
    function isSuperAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.status == 'active'
        && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'super_admin';
    }

    // Bootstrap state: no super_admins have been assigned yet
    function isBootstrapState() {
      return !exists(/databases/$(database)/documents/metadata/admin_config)
        || !('superAdmins' in get(/databases/$(database)/documents/metadata/admin_config).data)
        || get(/databases/$(database)/documents/metadata/admin_config).data.superAdmins.size() == 0;
    }

    // Checks the requesting user owns this document
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // ──────────────────────────────────────────────────────────────
    // PUBLIC WEBSITE CONTENT (read by everyone, write by active admins)
    // ──────────────────────────────────────────────────────────────

    match /events/{eventId} {
      allow read: if true;
      allow write: if isActiveAdmin();
    }

    match /gallery/{itemId} {
      allow read: if true;
      allow write: if isActiveAdmin();
    }

    match /execom/{memberId} {
      allow read: if true;
      allow write: if isActiveAdmin();
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if isActiveAdmin();
    }

    // ──────────────────────────────────────────────────────────────
    // AUDIT LOGS
    // ──────────────────────────────────────────────────────────────

    match /adminAuditLogs/{logId} {
      allow read:   if isActiveAdmin();
      // Any authenticated user can write audit logs (needed for bootstrap and access requests)
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // ──────────────────────────────────────────────────────────────
    // METADATA / CONFIG
    // ──────────────────────────────────────────────────────────────

    match /metadata/{docId} {
      allow read:  if request.auth != null;
      allow write: if isSuperAdmin() || isBootstrapState();
    }

    // ──────────────────────────────────────────────────────────────
    // ADMINS COLLECTION
    // ──────────────────────────────────────────────────────────────

    match /admins/{uid} {
      // Any authenticated user can read their own record;
      // active admins can read all records (needed to load the admins list in the dashboard)
      allow read: if isOwner(uid) || isActiveAdmin();

      // Bootstrap: first sign-in creates the super admin record
      // Super admin: can create/update/delete other admins (not themselves)
      allow create: if isBootstrapState() || (isSuperAdmin() && !isOwner(uid));
      allow update: if isBootstrapState() || (isSuperAdmin() && !isOwner(uid));
      allow delete: if isSuperAdmin() && !isOwner(uid);
    }

    // ──────────────────────────────────────────────────────────────
    // ACCESS REQUESTS COLLECTION
    // ──────────────────────────────────────────────────────────────

    match /adminAccessRequests/{uid} {
      // Active admins can read all requests; owners can read their own
      allow read: if isActiveAdmin() || isOwner(uid);

      // Any signed-in user can create their OWN request document
      // (the document ID must equal their UID)
      allow create: if isOwner(uid) && request.resource.data.status == 'pending';

      // Owners can update only attempt metadata (cannot self-approve)
      // Super admins can update anything (approve / reject)
      allow update: if
        (isOwner(uid)
          && request.resource.data.status == resource.data.status
          && request.resource.data.uid    == resource.data.uid
          && request.resource.data.email  == resource.data.email
        ) || isSuperAdmin();

      // Only super admins can delete requests
      allow delete: if isSuperAdmin();
    }
  }
}
