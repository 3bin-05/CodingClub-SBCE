rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user is an active admin (any role)
    function isActiveAdmin() {
      return request.auth != null && 
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.status == 'active';
    }

    // Helper function to check if the user is a super admin
    function isSuperAdmin() {
      return request.auth != null && 
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.status == 'active' &&
        get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'super_admin';
    }

    // Helper function to check if the database is in a bootstrap state (no super_admins exist)
    function isBootstrapState() {
      return !exists(/databases/$(database)/documents/metadata/admin_config) ||
        get(/databases/$(database)/documents/metadata/admin_config).data.superAdmins.size() == 0;
    }

    // Public website content collections
    match /events/{eventId} {
      allow read: if true;
      allow write: if isActiveAdmin();
    }

    match /gallery/{itemId} {
      allow read: if true;
      allow write: if isActiveAdmin();
    }

    match /execom/{memberId} {
      allow read: if true;
      allow write: if isActiveAdmin();
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if isActiveAdmin();
    }

    // Audit logs - read by any active admin, write by any active admin or during bootstrap
    match /adminAuditLogs/{logId} {
      allow read: if isActiveAdmin();
      allow create: if isActiveAdmin() || isBootstrapState();
    }

    // Metadata / Config
    match /metadata/{docId} {
      allow read: if request.auth != null;
      // Allow writing if user is super admin or if the database is empty (bootstrap)
      allow write: if isSuperAdmin() || isBootstrapState();
    }

    // Admins Collection
    match /admins/{uid} {
      allow read: if request.auth != null;
      // Write is allowed by super_admin (excluding self-writes) or bootstrap state
      allow write: if isBootstrapState() || (
        isSuperAdmin() && request.auth.uid != uid
      );
    }

    // Access Requests Collection
    match /adminAccessRequests/{uid} {
      // Admins can read all requests. Owners can read their own request.
      allow read: if isActiveAdmin() || (request.auth != null && request.auth.uid == uid);
      
      // Creating a request
      allow create: if request.auth != null && request.auth.uid == uid 
        && request.resource.data.status == 'pending'
        && request.resource.data.attemptCount == 1;

      // Updating a request
      allow update: if 
        // 1. Owners can only increment attempts and update lastAttemptAt, they cannot approve themselves
        (request.auth != null && request.auth.uid == uid 
          && request.resource.data.status == resource.data.status 
          && request.resource.data.email == resource.data.email
          && request.resource.data.displayName == resource.data.displayName
          && request.resource.data.firstRequestedAt == resource.data.firstRequestedAt
          && request.resource.data.attemptCount == resource.data.attemptCount + 1
        ) ||
        // 2. Super Admins can update status (approve/reject) and reviewedBy details
        isSuperAdmin();

      // Deleting requests is restricted to super admins
      allow delete: if isSuperAdmin();
    }
  }
}
